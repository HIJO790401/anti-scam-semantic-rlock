# LLM provider selector: bedrock or mock
LLM_PROVIDER=bedrock
DECISION_ENGINE_MODE=strict

# Bedrock wrapper settings
# Use a signed proxy/gateway URL that forwards to AWS Bedrock Runtime invoke API.
BEDROCK_INVOKE_URL=
BEDROCK_API_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_USE_SDK=true
AWS_REGION=us-west-2

# Optional request timeout (not hard-enforced in this demo)
AUDIT_TIMEOUT_MS=10000
